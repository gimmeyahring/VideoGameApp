<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:layout_editor_absoluteX="16dp"
        android:id="@+id/recomendationMediacardId"
        android:foreground="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/asphaltwhisper"
            android:orientation="vertical"
            >

            <ImageView
                android:id="@+id/recommendationMediacardImage"
                android:layout_width="550dp"
                android:layout_height="180dp"

                />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/recommendmeiacardtext"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:paddingStart="10dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/recommendMediacardtagContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacing="8dp"
                app:chipSpacingVertical="4dp"
                app:singleLine="false"
                android:paddingStart="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/loremispum"
                android:textSize="30dp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:paddingStart="15dp"
                android:id="@+id/recommendMediacardTitleTextView"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/loremispumparagraph"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="normal"
                android:paddingStart="15dp"
                android:id="@+id/recommendMediacardDescriptionTextView"
                android:maxLines="5"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>