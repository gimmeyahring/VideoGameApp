<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="top"
    android:id="@+id/main"
    android:background="@color/chromophobicblack"

    xmlns:android="http://schemas.android.com/apk/res/android">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/gamescrollviewid"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/herobannerid"
                    android:layout_width="match_parent"
                    android:layout_height="205dp"
                    android:src="@drawable/peakherobanner"
                    app:layout_constraintBottom_toTopOf="@+id/gametitleTextview"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.5" />

                <ImageView
                    android:id="@+id/herothumbnailid"
                    android:layout_width="137sp"
                    android:layout_height="211sp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="76dp"
                    android:background="@drawable/roundconers"
                    android:paddingHorizontal="2dp"
                    android:paddingVertical="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/gametitleTextview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="161dp"
                    android:layout_marginTop="132dp"
                    android:fontFamily="@font/robotovariablefontwdthwght"
                    android:text="@string/loremispum"
                    android:textColor="@color/white"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/tagContainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingStart="12dp"

                    app:chipSpacing="8dp"
                    app:singleLine="false"
                    app:chipSpacingVertical="0dp"


                    app:layout_constraintStart_toEndOf="@id/herothumbnailid"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/gametitleTextview"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:text="@string/Gamedesc"
                android:textColor="@color/white"
                android:textSize="30dp"
                android:textStyle="bold"
                android:paddingStart="15dp"
                android:paddingTop="5dp"/>

            <TextView
                android:id="@+id/gameexpandabledescriptionTextview"
                android:layout_width="373dp"
                android:layout_height="wrap_content"
                android:background="@drawable/roundconers"
                android:clickable="true"
                android:gravity="center"
                android:maxLines="6"
                android:paddingHorizontal="2sp"
                android:paddingVertical="5sp"
                android:text="@string/Loremispumparagraph"
                android:textColor="@color/white"
                android:textSize="15sp"
                 />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:text="@string/gameUp"
                android:textColor="@color/white"
                android:textSize="30dp"
                android:textStyle="bold"
                android:paddingStart="15dp"
                android:paddingTop="5dp"/>

            <TextView
                android:id="@+id/gameexpandableupdatesTextview"
                android:layout_width="373dp"
                android:layout_height="wrap_content"
                android:background="@drawable/roundconers"
                android:clickable="true"
                android:gravity="center"
                android:maxLines="6"
                android:paddingHorizontal="2sp"
                android:paddingVertical="5sp"
                android:text="@string/Loremispumparagraph"
                android:textColor="@color/white"
                android:textSize="15sp"
                />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/gamedev"
                    android:textColor="@color/white"
                    android:textSize="25sp"
                    android:textStyle="normal"
                    android:paddingTop="5dp"
                    android:paddingEnd="15dp"/>

                <TextView
                    android:id="@+id/gamedeveloperTextview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/loremispum"
                    android:textColor="@color/coolblue"
                    android:textSize="25sp"
                    android:textStyle="italic"
                    android:paddingTop="5dp"/>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/gamepub"
                    android:textColor="@color/white"
                    android:textSize="25sp"
                    android:textStyle="normal"
                    android:paddingTop="5dp"
                    android:paddingEnd="15dp"/>

                <TextView
                    android:id="@+id/gamepublisherTextview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/loremispum"
                    android:textColor="@color/coolblue"
                    android:textSize="25sp"
                    android:textStyle="italic"
                    android:paddingTop="5dp"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

        </LinearLayout>

    </ScrollView>
</LinearLayout>